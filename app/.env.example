# Copy to .env and fill in. Never commit .env.
DATABASE_URL="file:/var/lib/gavah/gavah.db"

# Cloudflare R2 (S3-compatible). Leave R2_ACCOUNT_ID empty to run WITHOUT R2:
# media is then stored on local disk (GAVAH_MEDIA_DIR, default
# /var/lib/gavah/media) and served from /media/* — fine for demos and dev,
# switch to R2 before real traffic.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="gavah"
# Public base URL of the bucket (custom domain or r2.dev), no trailing slash
R2_PUBLIC_BASE_URL="https://media.example.com"
# GAVAH_MEDIA_DIR=""     # local-mode media dir override
# WHISPER_MODEL="small"  # worker transcription model (tiny/small/medium)

# Random 32+ char secret for session cookies
SESSION_SECRET=""

# Public URL of the app, no trailing slash
APP_URL="http://localhost:3000"

# Port `next start` listens on. nginx and scripts read this too — change it
# here (not in package.json/pm2) so everything stays in sync. Default 3000.
# PORT="3000"

# Telegram bot (notifications + approve/reject in chat). Leave empty to
# disable. Create the bot with @BotFather, then run:
#   bash scripts/setup-telegram.sh   (registers the webhook for you)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# M4 (billing) — leave empty until Stripe is wired up
BILLING_ENABLED=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
