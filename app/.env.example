# Copy to .env and fill in. Never commit .env.
DATABASE_URL="file:/var/lib/gavah/gavah.db"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="gavah"
# Public base URL of the bucket (custom domain or r2.dev), no trailing slash
R2_PUBLIC_BASE_URL="https://media.example.com"

# Random 32+ char secret for session cookies
SESSION_SECRET=""

# Public URL of the app, no trailing slash
APP_URL="http://localhost:3000"

# M4 (billing) — leave empty until Stripe is wired up
BILLING_ENABLED=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
